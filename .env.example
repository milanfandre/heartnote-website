# Heart Note — environment variables (set these in Vercel → Project → Settings → Environment Variables)
# Copy real values from your Stripe Dashboard. NEVER commit real keys.

# Stripe secret key (test: sk_test_... , live: sk_live_...)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (starts with whsec_ — created when you add the webhook endpoint)
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the three tiers (create Products/Prices in Stripe, paste the price_... IDs)
PRICE_SINGLE=
PRICE_DELUXE=
PRICE_KEEPSAKE=

# Where paid orders are handed off to your AI music workflow (POST as JSON).
# Leave blank for now — orders will be logged in the Vercel function logs until this is set.
AI_WORKFLOW_URL=
# Optional bearer token sent as Authorization header to the workflow endpoint.
AI_WORKFLOW_SECRET=
